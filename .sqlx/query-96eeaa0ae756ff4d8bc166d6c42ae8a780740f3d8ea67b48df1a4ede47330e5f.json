  "query": "\n            DELETE FROM pending_org_email_changes p\n            USING users u\n            WHERE p.token_hash = $1\n              AND p.organization_id = u.id\n              AND u.is_deleted = false\n            RETURNING p.id, p.organization_id, p.new_email, p.requested_by, p.created_at, p.expires_at\n            ",
