  "query": "\n            SELECT uo.user_id, uo.organization_id, uo.role, uo.created_at\n            FROM user_organizations uo\n            INNER JOIN users u ON u.id = uo.organization_id\n            WHERE uo.user_id = $1 AND u.is_deleted = false\n            ORDER BY uo.created_at ASC\n            ",
