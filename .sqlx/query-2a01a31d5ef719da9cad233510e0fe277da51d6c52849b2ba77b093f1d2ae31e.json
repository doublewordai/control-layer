  "query": "\n            SELECT w.*\n            FROM user_webhooks w\n            INNER JOIN user_roles ur ON ur.user_id = w.user_id\n            WHERE w.enabled = true\n              AND w.scope = 'platform'\n              AND w.disabled_at IS NULL\n              AND ur.role = 'PLATFORMMANAGER'\n            ",
