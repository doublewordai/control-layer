{
  "packages": {
    "dwctl": {
      "release-type": "rust",
      "changelog-path": "/CHANGELOG.md",
      "include-paths": ["dashboard"],
      "extra-files": [
        {
          "type": "json",
          "path": "/dashboard/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  },
  "plugins": ["cargo-workspace"],
  "include-component-in-tag": false
}
