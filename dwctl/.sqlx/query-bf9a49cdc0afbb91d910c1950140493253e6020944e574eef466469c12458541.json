{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                dm.alias,\n                mct.ttl_tier,\n                mct.write_multiplier,\n                mct.read_multiplier,\n                mct.valid_from,\n                mct.valid_until\n            FROM deployed_models dm\n            JOIN model_cache_tariffs mct ON mct.deployed_model_id = dm.id\n            WHERE dm.alias = ANY($1)\n            ORDER BY dm.alias, mct.valid_from DESC\n            ",
